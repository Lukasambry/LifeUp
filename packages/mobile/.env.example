# LifeUp Mobile Environment Variables
# Copie ce fichier en .env et remplis les valeurs

# URL du backend
# - Emulateur Android : http://10.0.2.2:3000
# - Device physique   : http://<ip-locale>:3000  (ex: http://192.168.1.42:3000)
# - iOS Simulator     : http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth - Web Client ID depuis Google Cloud Console
# https://console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Google OAuth - iOS Client ID (requis sur iOS)
# Google Cloud Console → Credentials → créer un client OAuth "iOS" avec le bundle ID de app.json
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
