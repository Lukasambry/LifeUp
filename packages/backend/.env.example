# LifeUp Backend Environment Variables

# Database (PostgreSQL)
DATABASE_URL="postgresql://lifeup:lifeup_password@localhost:5435/lifeup_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6380"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"

# CORS (comma-separated origins)
CORS_ORIGIN="http://localhost:3001,http://localhost:8081"

# Mail (SMTP)
# Dev: Mailpit inclus dans docker-compose (UI: http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=       # pas nécessaire avec Mailpit
# SMTP_PASS=       # pas nécessaire avec Mailpit
MAIL_FROM="LifeUp <noreply@lifeup.app>"

# App URL (used in email links)
APP_URL="http://localhost:3001"
