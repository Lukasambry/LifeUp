generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String              @id @default(uuid())
  email                  String              @unique
  username               String              @unique
  passwordHash           String              @map("password_hash")
  ssoProvider            SSOProvider?        @map("sso_provider")
  ssoId                  String?             @map("sso_id")
  avatarUrl              String?             @map("avatar_url")
  level                  Int                 @default(1)
  totalXp                BigInt              @default(0) @map("total_xp")
  class                  UserClass?
  isHardcore             Boolean             @default(false) @map("is_hardcore")
  trustScore             Int                 @default(100) @map("trust_score")
  isPublic               Boolean             @default(true) @map("is_public")
  address                String?
  latitude               Float?
  longitude              Float?
  locationConsent        Boolean             @default(false) @map("location_consent")
  totpSecret             String?             @map("totp_secret")
  passwordChangedAt      DateTime?           @map("password_changed_at")
  failedLoginAttempts    Int                 @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime?           @map("locked_until")
  deletedAt              DateTime?           @map("deleted_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  challenged             Challenge[]         @relation("ChallengedUser")
  challenger             Challenge[]         @relation("ChallengerUser")
  wonChallenges          Challenge[]         @relation("ChallengeWinner")
  messages               ChatMessage[]
  resolvedFlags          FraudFlag[]         @relation("ResolverFlags")
  fraudFlags             FraudFlag[]         @relation("UserFlags")
  receivedFriendRequests Friendship[]        @relation("ReceivedFriendships")
  sentFriendRequests     Friendship[]        @relation("SentFriendships")
  guildMemberships       GuildMember[]
  ledGuild               Guild?              @relation("GuildLeader")
  hardcoreSettings       HardcoreSettings?
  nfcTags                NfcTag[]
  notifications          Notification[]
  seasonProgress         SeasonProgress[]
  completions            TaskCompletion[]
  ownTasks               Task[]              @relation("CreatedTasks")
  achievements           UserAchievement[]
  inventory              UserInventory[]
  stats                  UserStats?
  userTalents            UserTalent[]
  tasks                  UserTask[]
  wallet                 UserWallet?
  transactions           WalletTransaction[]

  @@map("users")
}

model UserStats {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  strength     Int      @default(0)
  intelligence Int      @default(0)
  agility      Int      @default(0)
  endurance    Int      @default(0)
  charisma     Int      @default(0)
  wisdom       Int      @default(0)
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@map("user_stats")
}

model Task {
  id                  String           @id @default(uuid())
  name                String
  description         String?
  category            TaskCategory
  type                TaskType
  baseXp              Int              @map("base_xp")
  cooldownMinutes     Int?             @map("cooldown_minutes")
  isPredefined        Boolean          @map("is_predefined")
  createdBy           String?          @map("created_by")
  requiresProof       Boolean          @default(false) @map("requires_proof")
  maxDailyCompletions Int              @default(1) @map("max_daily_completions")
  createdAt           DateTime         @default(now()) @map("created_at")
  challenges          Challenge[]
  completions         TaskCompletion[]
  creator             User?            @relation("CreatedTasks", fields: [createdBy], references: [id])
  userInstances       UserTask[]
  nfcTags             NfcTag[]         @relation("TaskNfcTags")

  @@unique([name, isPredefined], name: "name_isPredefined")
  @@map("tasks")
}

model UserTask {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  taskId          String    @map("task_id")
  isActive        Boolean   @map("is_active")
  currentStreak   Int       @default(0) @map("current_streak")
  bestStreak      Int       @default(0) @map("best_streak")
  lastCompletedAt DateTime? @map("last_completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  task            Task      @relation(fields: [taskId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@map("user_tasks")
}

model TaskCompletion {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  taskId      String   @map("task_id")
  xpEarned    Int      @map("xp_earned")
  multiplier  Float    @default(1.0)
  proofUrl    String?  @map("proof_url")
  nfcTagId    String?  @map("nfc_tag_id")
  gpsLat      Float?   @map("gps_lat")
  gpsLng      Float?   @map("gps_lng")
  flagged     Boolean  @default(false)
  completedAt DateTime @map("completed_at")
  ipAddress   String?  @map("ip_address")
  nfcTag      NfcTag?  @relation(fields: [nfcTagId], references: [id])
  task        Task     @relation(fields: [taskId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@map("task_completions")
}

model NfcTag {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  nfcUid       String           @unique @map("nfc_uid")
  label        String
  latitude     Float
  longitude    Float
  radiusMeters Int              @default(100) @map("radius_meters")
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  user         User             @relation(fields: [userId], references: [id])
  completions  TaskCompletion[]
  tasks        Task[]           @relation("TaskNfcTags")

  @@map("nfc_tags")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus
  createdAt   DateTime         @default(now()) @map("created_at")
  addressee   User             @relation("ReceivedFriendships", fields: [addresseeId], references: [id])
  requester   User             @relation("SentFriendships", fields: [requesterId], references: [id])

  @@map("friendships")
}

model Guild {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  avatarUrl   String?       @map("avatar_url")
  leaderId    String        @unique @map("leader_id")
  maxMembers  Int           @default(30) @map("max_members")
  totalXp     BigInt        @default(0) @map("total_xp")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  messages    ChatMessage[]
  members     GuildMember[]
  quests      GuildQuest[]
  leader      User          @relation("GuildLeader", fields: [leaderId], references: [id])

  @@map("guilds")
}

model GuildMember {
  id            String    @id @default(uuid())
  guildId       String    @map("guild_id")
  userId        String    @map("user_id")
  role          GuildRole
  joinedAt      DateTime  @default(now()) @map("joined_at")
  xpContributed BigInt    @default(0) @map("xp_contributed")
  guild         Guild     @relation(fields: [guildId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@map("guild_members")
}

model GuildQuest {
  id            String      @id @default(uuid())
  guildId       String      @map("guild_id")
  title         String
  description   String?
  xpTarget      BigInt      @map("xp_target")
  xpCurrent     BigInt      @default(0) @map("xp_current")
  rewardXpBonus Int         @map("reward_xp_bonus")
  startsAt      DateTime    @map("starts_at")
  endsAt        DateTime    @map("ends_at")
  status        QuestStatus
  createdAt     DateTime    @default(now()) @map("created_at")
  guild         Guild       @relation(fields: [guildId], references: [id])

  @@map("guild_quests")
}

model Challenge {
  id           String          @id @default(uuid())
  type         ChallengeType
  challengerId String          @map("challenger_id")
  challengedId String          @map("challenged_id")
  taskId       String?         @map("task_id")
  status       ChallengeStatus
  winnerId     String?         @map("winner_id")
  startsAt     DateTime        @map("starts_at")
  endsAt       DateTime        @map("ends_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  challenged   User            @relation("ChallengedUser", fields: [challengedId], references: [id])
  challenger   User            @relation("ChallengerUser", fields: [challengerId], references: [id])
  task         Task?           @relation(fields: [taskId], references: [id])
  winner       User?           @relation("ChallengeWinner", fields: [winnerId], references: [id])

  @@map("challenges")
}

model ChatMessage {
  id        String    @id @default(uuid())
  guildId   String    @map("guild_id")
  senderId  String    @map("sender_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  guild     Guild     @relation(fields: [guildId], references: [id])
  sender    User      @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  sentAt    DateTime         @default(now()) @map("sent_at")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Achievement {
  id               String            @id @default(uuid())
  name             String            @unique
  description      String?
  iconUrl          String?           @map("icon_url")
  condition        Json
  xpReward         Int               @map("xp_reward")
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  achievementId String      @map("achievement_id")
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@map("user_achievements")
}

model FraudFlag {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  flagType   FraudType @map("flag_type")
  severity   Severity
  details    Json?
  resolved   Boolean   @default(false)
  resolvedBy String?   @map("resolved_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  resolver   User?     @relation("ResolverFlags", fields: [resolvedBy], references: [id])
  user       User      @relation("UserFlags", fields: [userId], references: [id])

  @@map("fraud_flags")
}

model Season {
  id             String           @id @default(uuid())
  name           String
  themeStat      TaskCategory?    @map("theme_stat")
  xpBonusPercent Int              @map("xp_bonus_percent")
  startsAt       DateTime         @map("starts_at")
  endsAt         DateTime         @map("ends_at")
  isActive       Boolean          @default(false) @map("is_active")
  rewards        Json
  createdAt      DateTime         @default(now()) @map("created_at")
  progress       SeasonProgress[]
  shopItems      ShopItem[]

  @@map("seasons")
}

model SeasonProgress {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  seasonId       String   @map("season_id")
  seasonXp       BigInt   @default(0) @map("season_xp")
  tierReached    Int      @default(0) @map("tier_reached")
  rewardsClaimed Json     @map("rewards_claimed")
  updatedAt      DateTime @updatedAt @map("updated_at")
  season         Season   @relation(fields: [seasonId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@map("season_progress")
}

model TalentTree {
  id                   String       @id @default(uuid())
  stat                 TaskCategory
  name                 String
  description          String?
  tier                 Int
  requiredStatLevel    Int          @map("required_stat_level")
  prerequisiteTalentId String?      @map("prerequisite_talent_id")
  effect               Json
  createdAt            DateTime     @default(now()) @map("created_at")
  prerequisite         TalentTree?  @relation("TalentPrerequisite", fields: [prerequisiteTalentId], references: [id])
  dependents           TalentTree[] @relation("TalentPrerequisite")
  userTalents          UserTalent[]

  @@unique([stat, name], name: "stat_name")
  @@map("talent_trees")
}

model UserTalent {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  talentId   String       @map("talent_id")
  stat       TaskCategory
  unlockedAt DateTime     @default(now()) @map("unlocked_at")
  talent     TalentTree   @relation(fields: [talentId], references: [id])
  user       User         @relation(fields: [userId], references: [id])

  @@unique([userId, talentId])
  @@map("user_talents")
}

model ShopItem {
  id           String          @id @default(uuid())
  name         String
  description  String?
  category     ShopCategory
  priceGc      Int             @map("price_gc")
  iconUrl      String?         @map("icon_url")
  effect       Json?
  seasonId     String?         @map("season_id")
  maxPurchases Int?            @map("max_purchases")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  season       Season?         @relation(fields: [seasonId], references: [id])
  inventory    UserInventory[]

  @@map("shop_items")
}

model UserInventory {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  itemId      String    @map("item_id")
  isEquipped  Boolean   @default(false) @map("is_equipped")
  purchasedAt DateTime  @default(now()) @map("purchased_at")
  expiresAt   DateTime? @map("expires_at")
  item        ShopItem  @relation(fields: [itemId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, itemId])
  @@map("user_inventory")
}

model UserWallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  goldCoins Int      @default(0) @map("gold_coins")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("user_wallet")
}

model WalletTransaction {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  amount      Int
  reason      TransactionReason
  referenceId String?           @map("reference_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  user        User              @relation(fields: [userId], references: [id])

  @@map("wallet_transactions")
}

model HardcoreSettings {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  isActive      Boolean   @default(false) @map("is_active")
  activatedAt   DateTime? @map("activated_at")
  deactivatedAt DateTime? @map("deactivated_at")
  cooldownUntil DateTime? @map("cooldown_until")
  deathCount    Int       @default(0) @map("death_count")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id])

  @@map("hardcore_settings")
}

enum SSOProvider {
  GOOGLE
  APPLE
}

enum UserClass {
  WARRIOR
  MAGE
  THIEF
  ARCHER
  PALADIN
  BARD
}

enum TaskCategory {
  STRENGTH
  INTELLIGENCE
  AGILITY
  ENDURANCE
  CHARISMA
  WISDOM
}

enum TaskType {
  DAILY
  WEEKLY
  MONTHLY
  ONESHOT
  REPEATABLE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum ChallengeType {
  DUEL
  GUILD_VS_GUILD
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
}

enum NotificationType {
  STREAK_WARNING
  LEVEL_UP
  FRIEND_REQUEST
  GUILD_INVITE
  CHALLENGE
  NUDGE
  REMINDER
}

enum FraudType {
  RATE_ABUSE
  SUSPICIOUS_TIME
  PATTERN_ANOMALY
  COMMUNITY_REPORT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum ShopCategory {
  AVATAR
  TITLE
  THEME
  BOOST
}

enum TransactionReason {
  TASK_COMPLETION
  ACHIEVEMENT
  DUEL_WIN
  GUILD_QUEST
  SEASON_REWARD
  SHOP_PURCHASE
}
